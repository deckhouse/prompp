{
  "timeseries_loaded_blocks": {
    "type": "timeseries",
    "title": "Loaded TSDB Blocks",
    "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
    },
    "targets": [
      {
        "refId": "A",
        "expr": "sum by (job, instance) (prometheus_tsdb_blocks_loaded{job=~\"$job\",instance=~\"$instance\"})",
        "legendFormat": "{{job}} {{instance}}"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "none",
        "min": 0
      },
      "overrides": []
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom"
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  "timeseries_loaded_blocks_by_duration": {
    "type": "timeseries",
    "title": "Loaded TSDB Blocks by Duration",
    "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
    },
    "targets": [
      {
        "refId": "A",
        "expr": "sum by (job, instance, duration_minutes) (prometheus_tsdb_blocks_loaded_by_duration{job=~\"$job\",instance=~\"$instance\"})",
        "legendFormat": "{{job}} {{instance}} {{duration_minutes}}m"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "none",
        "min": 0
      },
      "overrides": []
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom"
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  "heatmap_loaded_blocks_by_duration": {
    "type": "heatmap",
    "title": "Loaded TSDB Blocks by Duration (Heatmap)",
    "datasource": {
      "type": "prometheus",
      "uid": "${DS_PROMETHEUS}"
    },
    "targets": [
      {
        "refId": "A",
        "expr": "sum by (duration_minutes) (prometheus_tsdb_blocks_loaded_by_duration{job=~\"$job\",instance=~\"$instance\"})",
        "legendFormat": "{{duration_minutes}}m"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "none",
        "min": 0
      },
      "overrides": []
    },
    "options": {
      "calculate": false,
      "cellGap": 1,
      "color": {
        "mode": "scheme",
        "scheme": "Spectral"
      },
      "legend": {
        "show": true
      },
      "rowsFrame": {
        "layout": "auto"
      },
      "tooltip": {
        "show": true,
        "yHistogram": false
      },
      "yAxis": {
        "axisPlacement": "left",
        "reverse": false,
        "unit": "none"
      }
    }
  }
}
