# External dependencies are managed exclusively via Bzlmod (MODULE.bazel).
# --noenable_workspace ensures the legacy pp/WORKSPACE file (kept as a
# historical stub) is ignored even on Bazel versions that still accept it.
common --noenable_workspace

# This flag fixed bazel build error (tested on 7.* versions)
build --noreuse_sandbox_directories
build --fission=yes
build --flag_alias=march=//bazel/toolchain:march
build --flag_alias=asan=//bazel/toolchain:asan

# Profiling specific flags
build --flag_alias=profiling=//bazel/toolchain:profiling
build --flag_alias=profiling_opts=//bazel/toolchain:profiling_opts

# clang-tidy specific flags
build:clang-tidy --//bazel/toolchain:clang_tidy
